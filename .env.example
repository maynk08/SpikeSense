# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Discord Incoming Webhook URL for anomaly alerts.
# Create one at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Override the API base URL used by the Streamlit dashboard.
# In production this is the Render deployment URL.
SPIKE_SENSE_API_URL=http://localhost:8000
